From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: YKSam <1876421041@qq.com>
Date: Tue, 24 Mar 2026 20:40:00 +0800
Subject: [PATCH] PCI: add DG1 passthrough quirk

Add a dedicated quirk for Intel DG1 passthrough devices to limit
config space and disable reset paths that can hang the device.

Covers Intel DG1 IDs 0x4905 and 0x4908.
---
 drivers/pci/quirks.c | 14 ++++++++++++++
 1 file changed, 14 insertions(+)

diff --git a/drivers/pci/quirks.c b/drivers/pci/quirks.c
index 21e1acd3cffe..6f7644b2cb58 100644
--- a/drivers/pci/quirks.c
+++ b/drivers/pci/quirks.c
@@ -6497,3 +6497,17 @@ static void pci_mask_replay_timer_timeout(struct pci_dev *pdev)
 DECLARE_PCI_FIXUP_FINAL(PCI_VENDOR_ID_GLI, 0x9750, pci_mask_replay_timer_timeout);
 DECLARE_PCI_FIXUP_FINAL(PCI_VENDOR_ID_GLI, 0x9755, pci_mask_replay_timer_timeout);
 #endif
+
+/* Work around reset issues on DG1 passthrough devices. */
+static void quirk_intel_dg1_pve_fix(struct pci_dev *dev)
+{
+	pci_info(dev, "DG1: apply passthrough fix (limit caps and disable reset)\n");
+
+	dev->cfg_size = PCI_CFG_SPACE_SIZE;
+	dev->dev_flags |= PCI_DEV_FLAGS_NO_FLR_RESET;
+	dev->dev_flags |= PCI_DEV_FLAGS_NO_PM_RESET;
+	dev->dev_flags |= PCI_DEV_FLAGS_NO_BUS_RESET;
+}
+
+DECLARE_PCI_FIXUP_HEADER(PCI_VENDOR_ID_INTEL, 0x4905, quirk_intel_dg1_pve_fix);
+DECLARE_PCI_FIXUP_HEADER(PCI_VENDOR_ID_INTEL, 0x4908, quirk_intel_dg1_pve_fix);
